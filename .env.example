# Alpca configuration — copy to .env and fill in. NEVER commit .env.
# Alpaca PAPER trading credentials (https://app.alpaca.markets/ -> Paper account -> API Keys)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Endpoints (defaults target PAPER — do not point at live without intent)
ALPACA_PAPER=1
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Market-data websocket feed: iex (free) or sip (paid)
ALPACA_DATA_FEED=iex

# --- Data API keys (research pipeline; all optional) ---
# Alpha Vantage earnings (free = 25 req/day). SEC EDGAR + FINRA need NO key (preferred for breadth).
ALPHAVANTAGE_API_KEY=

# --- AI strategy-loop models (alpca/ai/router.py; see docs/SYSTEM_MAP.md §6) ---
# Haiku = cheap/fast small tasks; OpenAI medium = heavier reasoning. Read from env only, never logged.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# ALPCA_HAIKU_MODEL=claude-haiku-4-5
# ALPCA_OPENAI_MODEL=gpt-4o

# --- Risk limits (override defaults; all optional) ---
RISK_MAX_ORDER_NOTIONAL=50000
RISK_DAILY_LOSS_PCT=0.02
RISK_MAX_CONCENTRATION_PCT=0.25
RISK_MAX_OPEN_POSITIONS=20
RISK_MAX_ORDERS_PER_MIN=60
